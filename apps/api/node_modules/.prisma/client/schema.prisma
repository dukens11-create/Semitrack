generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DRIVER
  ADMIN
  FLEET_ADMIN
}

enum SubscriptionPlan {
  FREE
  GOLD
  DIAMOND
  TEAM
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  passwordHash String
  fullName     String
  phone        String?
  role         UserRole         @default(DRIVER)
  plan         SubscriptionPlan @default(FREE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  trucks       Truck[]
  trips        Trip[]
  documents    Document[]
}

model Truck {
  id            String   @id @default(cuid())
  userId        String
  name          String
  unitNumber    String?
  trailerNumber String?
  heightFt      Float
  weightLbs     Int
  widthFt       Float
  lengthFt      Float
  hazmatEnabled Boolean  @default(false)
  axleCount     Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id               String   @id @default(cuid())
  userId           String
  name             String
  originName       String
  destinationName  String
  originLat        Float
  originLng        Float
  destinationLat   Float
  destinationLng   Float
  etaMinutes       Int?
  distanceMiles    Float?
  routeProvider    String?
  routePolyline    String?
  hosBreakPlanJson Json?
  fuelPlanJson     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParkingReport {
  id        String   @id @default(cuid())
  userId    String
  lotName   String
  status    String
  notes     String?
  createdAt DateTime @default(now())
}

model Load {
  id               String   @id @default(cuid())
  brokerName       String
  originCity       String
  originState      String
  destinationCity  String
  destinationState String
  equipmentType    String
  weightLbs        Int?
  rateUsd          Float?
  createdAt        DateTime @default(now())
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  type      String
  fileName  String
  fileUrl   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
